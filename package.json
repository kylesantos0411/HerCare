{
  "name": "hercare",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:simple": "powershell -Command \"$env:VITE_APP_VARIANT='simple'; npm.cmd run dev\"",
    "build": "tsc -b && vite build",
    "build:simple": "powershell -Command \"$env:VITE_APP_VARIANT='simple'; npm.cmd run build\"",
    "apk:debug": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1",
    "apk:simple:debug": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1 -AppVariant simple",
    "apk:release": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1 -Release",
    "apk:simple:release": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1 -Release -AppVariant simple",
    "aab:release": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1 -Bundle",
    "aab:simple:release": "powershell -ExecutionPolicy Bypass -File ./build-apk.ps1 -Bundle -AppVariant simple",
    "push:deploy": "npx firebase-tools deploy --only functions",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "classnames": "^2.5.1",
    "firebase": "^12.11.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
